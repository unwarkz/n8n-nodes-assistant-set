{
  "name": "@unwarkz/n8n-nodes-qdrant",
  "version": "1.0.0",
  "description": "N8N community node for Qdrant vector store — semantic search, embedding storage, and full collection management for AI Agent workflows",
  "license": "MIT",
  "homepage": "https://github.com/unwarkz/n8n-nodes-mem0-api-server#readme",
  "author": {
    "name": "unwarkz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unwarkz/n8n-nodes-mem0-api-server.git"
  },
  "bugs": {
    "url": "https://github.com/unwarkz/n8n-nodes-mem0-api-server/issues"
  },
  "main": "index.js",
  "scripts": {
    "prepublishOnly": "echo 'Skipping build - dist files are pre-built'"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/QdrantApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/qdrant/QdrantStoreAiTools.node.js",
      "dist/nodes/qdrant/QdrantAiTools.node.js"
    ]
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "qdrant",
    "vector-store",
    "vector-database",
    "embeddings",
    "semantic-search",
    "rag",
    "retrieval-augmented-generation",
    "ai",
    "llm",
    "knowledgebase",
    "multimodal"
  ],
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
