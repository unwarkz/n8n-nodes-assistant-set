{
  "name": "@unwarkz/n8n-nodes-telegram-bot",
  "version": "1.0.2",
  "description": "N8N community node for Telegram Bot API - full coverage of all Bot API methods with AI Agent tools",
  "license": "MIT",
  "homepage": "https://github.com/unwarkz/n8n-nodes-mem0-api-server#readme",
  "author": {
    "name": "unwarkz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unwarkz/n8n-nodes-mem0-api-server.git"
  },
  "bugs": {
    "url": "https://github.com/unwarkz/n8n-nodes-mem0-api-server/issues"
  },
  "main": "index.js",
  "scripts": {
    "prepublishOnly": "echo 'Skipping build - dist files are pre-built'"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TelegramBotApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/telegram/TelegramBot.node.js",
      "dist/nodes/telegram/TelegramBotAiTools.node.js"
    ]
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "telegram",
    "telegram-bot",
    "bot-api",
    "ai",
    "llm",
    "chat-bot",
    "messaging"
  ],
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
