{
  "name": "@unwarkz/n8n-nodes-assistant-set",
  "version": "1.1.4",
  "description": "N8N community node package — full assistant set: Mem0 memory, Gotenberg PDF, Telegram Bot, Outline Wiki, Qdrant vector store (regular + AI tools)",
  "license": "MIT",
  "homepage": "https://github.com/unwarkz/n8n-nodes-assistant-set#readme",
  "author": {
    "name": "unwarkz <unwarkz@gmail.com>"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unwarkz/n8n-nodes-assistant-set.git"
  },
  "bugs": {
    "url": "https://github.com/unwarkz/n8n-nodes-assistant-set/issues"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "lintfix": "tslint --fix -p tsconfig.json -c tslint.json",
    "prepublishOnly": "echo 'Skipping build - dist files are pre-built'"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/Mem0Api.credentials.js",
      "dist/credentials/Mem0SelfHostedApi.credentials.js",
      "dist/credentials/GotenbergApi.credentials.js",
      "dist/credentials/TelegramBotApi.credentials.js",
      "dist/credentials/OutlineApi.credentials.js",
      "dist/credentials/QdrantApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Mem0/Mem0.node.js",
      "dist/nodes/Mem0/Mem0Memory.node.js",
      "dist/nodes/Mem0/Mem0AiTools.node.js",
      "dist/nodes/gotenberg/Gotenberg.node.js",
      "dist/nodes/gotenberg/GotenbergAiTools.node.js",
      "dist/nodes/telegram/TelegramBot.node.js",
      "dist/nodes/telegram/TelegramBotAiTools.node.js",
      "dist/nodes/outline/Outline.node.js",
      "dist/nodes/outline/OutlineAiTools.node.js",
      "dist/nodes/qdrant/QdrantStoreAiTools.node.js",
      "dist/nodes/qdrant/QdrantAiTools.node.js"
    ]
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "assistant",
    "mem0",
    "memory",
    "ai",
    "llm",
    "gotenberg",
    "pdf",
    "telegram",
    "telegram-bot",
    "bot-api",
    "outline",
    "wiki",
    "knowledge-base",
    "outline-wiki",
    "qdrant",
    "vector-store",
    "vector-database",
    "embeddings",
    "semantic-search",
    "rag",
    "knowledgebase"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "gulp": "^5.0.0",
    "n8n-workflow": "^1.250.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "eslint": "^9.x"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.250.0"
  }
}
